{
  "manifest_version": 2,
  "name": "Gain - Volume Booster",
  "version": "1.0.2",
  "description": "Boost volume up to 600% on any tab. Volume amplifier and booster with bass boost, voice boost, and per-site memory.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    },
    "default_popup": "popup.html",
    "default_title": "Gain - Volume Booster"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  "optional_permissions": [
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "gain-volume-booster@hookset",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "background": {
    "scripts": ["site-utils.js", "background.js"],
    "persistent": false
  }
}
